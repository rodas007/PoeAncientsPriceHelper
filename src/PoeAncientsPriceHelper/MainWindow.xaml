<mah:MetroWindow x:Class="PoeAncientsPriceHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="Poe Ancients Price Helper" Height="450" Width="500"
        Icon="app.ico"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F0F"
        Foreground="#E0E0E0"
        BorderBrush="#2A2A2A"
        TitleCharacterCasing="Normal"
        Closing="Window_Closing">

    <mah:MetroWindow.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#999"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="League:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="LeagueBox" Margin="0,4" SelectionChanged="LeagueBox_SelectionChanged"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Region:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RegionLabel" Text="Not calibrated" Foreground="#666" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Start/Stop key:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
            <TextBlock x:Name="HotkeyLabel" Text="F5" VerticalAlignment="Center"
                       FontFamily="Consolas" FontSize="12" Foreground="#E0E0E0" MinWidth="46"/>
            <Button x:Name="RebindButton" Content="Rebind" Padding="10,2" FontSize="11"
                    Click="RebindButton_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Debug overlay key:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
            <TextBlock x:Name="DebugHotkeyLabel" Text="F3" VerticalAlignment="Center"
                       FontFamily="Consolas" FontSize="12" Foreground="#E0E0E0" MinWidth="46"/>
            <Button x:Name="RebindDebugButton" Content="Rebind" Padding="10,2" FontSize="11"
                    Click="RebindDebugButton_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Calibrate key:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
            <TextBlock x:Name="CalibrateHotkeyLabel" Text="F4" VerticalAlignment="Center"
                       FontFamily="Consolas" FontSize="12" Foreground="#E0E0E0" MinWidth="46"/>
            <Button x:Name="RebindCalibrateButton" Content="Rebind" Padding="10,2" FontSize="11"
                    Click="RebindCalibrateButton_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button x:Name="CalibrateButton" Content="Calibrate Region" Padding="10,4" FontSize="11"
                    Click="CalibrateButton_Click" HorizontalAlignment="Left"/>
            <Button x:Name="AutoDetectButton" Content="Auto-Detect" Padding="10,4" FontSize="11"
                    Click="AutoDetectButton_Click" Margin="8,0,0,0" HorizontalAlignment="Left"
                    ToolTip="Auto-detect the exchange panel on screen"/>
        </StackPanel>

        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,4,0,0">
            <TextBlock Text="Refresh:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="RefreshBox" Width="60" SelectionChanged="RefreshBox_SelectionChanged">
                <ComboBoxItem Content="15 min" Tag="15"/>
                <ComboBoxItem Content="30 min" Tag="30" IsSelected="True"/>
                <ComboBoxItem Content="60 min" Tag="60"/>
            </ComboBox>
            <CheckBox x:Name="SoundAlertCheck" Content="Snipe sound" IsChecked="True"
                      Margin="16,0,0,0" VerticalAlignment="Center" Foreground="#999" FontSize="11"
                      Checked="SoundAlert_Changed" Unchecked="SoundAlert_Changed"/>
        </StackPanel>

        <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,4,0,0">
            <TextBlock Text="Currency:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="CurrencyModeBox" Width="80" SelectionChanged="CurrencyMode_Changed">
                <ComboBoxItem Content="Exalted" Tag="Exalted" IsSelected="True"/>
                <ComboBoxItem Content="Chaos" Tag="Chaos"/>
                <ComboBoxItem Content="Divine" Tag="Divine"/>
            </ComboBox>
            <CheckBox x:Name="CrossCurrencyCheck" Content="Show divine if >1d" IsChecked="False"
                      Margin="16,0,0,0" VerticalAlignment="Center" Foreground="#999" FontSize="11"
                      Checked="CrossCurrency_Changed" Unchecked="CrossCurrency_Changed"/>
            <CheckBox x:Name="ExpensiveSoundCheck" Content="Loud alert >1d" IsChecked="True"
                      Margin="16,0,0,0" VerticalAlignment="Center" Foreground="#999" FontSize="11"
                      Checked="ExpensiveSound_Changed" Unchecked="ExpensiveSound_Changed"/>
        </StackPanel>

        <TextBlock Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                   x:Name="StatusLabel"
                   Text="Idle — prices not loaded"
                   Foreground="#666" FontSize="11" Margin="0,10,0,0"/>

        <Button Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                x:Name="StartStopButton"
                Content="Start" IsEnabled="False"
                Margin="0,10,0,0"
                Background="#1A3A1A" Foreground="#66FF66" BorderBrush="#337733"
                Click="StartStopButton_Click"/>

        <TextBlock Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2"
                   x:Name="VersionLabel"
                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                   Foreground="#666" FontSize="11"/>

        <TextBlock Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2"
                   x:Name="UpdateLink"
                   HorizontalAlignment="Center" VerticalAlignment="Bottom"
                   Foreground="#FF5555" FontSize="11" FontWeight="SemiBold"
                   Cursor="Hand" Visibility="Collapsed" TextDecorations="Underline"
                   MouseLeftButtonUp="UpdateLink_Click"/>

        <Button Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2"
                x:Name="DonateButton"
                Content="☕ Buy me a coffee"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Padding="10,4" FontSize="11" Cursor="Hand"
                Background="#3A2A12" Foreground="#E0B060" BorderBrush="#7A5A20"
                ToolTip="Support development via PayPal — thank you!"
                Click="DonateButton_Click"/>
    </Grid>
</mah:MetroWindow>
